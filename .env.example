# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Model — use 8b for demos (free tier friendly), 70b for eval runs
LLM_MODEL=llama-3.1-8b-instant
# LLM_MODEL=llama-3.3-70b-versatile

# Embedding model (downloaded automatically on first run)
EMBED_MODEL=all-MiniLM-L6-v2

# Vector store path
CHROMA_PATH=./chroma_db

# Confidence threshold for human review queue (claims below this get flagged)
CONFIDENCE_THRESHOLD=0.8

# Database (SQLite default — change to PostgreSQL URL for production)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/finaudit
